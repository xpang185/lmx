{
  "name": "@xpang/lmx",
  "version": "0.2.0",
  "description": "LLM executables powered by Pi",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xpang185/lmx.git"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lmx": "dist/cli.js",
    "judge": "dist/built-ins/judge/_run.js",
    "summarize": "dist/built-ins/summarize/_run.js",
    "classify": "dist/built-ins/classify/_run.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "test": "npm run check"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
